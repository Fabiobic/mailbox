{
    "name": "bicciato/mailbox",
    "description": "Applicazione PHP per gestione email da file PST Outlook con MySQL",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "php-mime-mail-parser/php-mime-mail-parser": "^5.0",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.0",
        "league/csv": "^9.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Mailbox\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
