DB_HOST=localhost
DB_NAME=mailbox
DB_USER=root
DB_PASS=

# Path assoluto alla cartella storage (senza slash finale)
STORAGE_PATH=/var/www/mailbox/storage

# Dimensione massima upload PST in MB
MAX_UPLOAD_MB=2048

# Path a readpst (installare con: apt-get install pst-utils)
READPST_PATH=/usr/bin/readpst

# Nome applicazione
APP_NAME="Mailbox - PST Manager"
APP_URL=http://localhost/mailbox
APP_DEBUG=false

# Sessione
SESSION_NAME=mailbox_session
